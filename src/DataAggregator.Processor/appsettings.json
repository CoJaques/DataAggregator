{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },

  "AllowedHosts": "*",
  "RegistrationService": {
    "Endpoint": "http://localhost:5001"
  },

  "PredictionService": {
    "RegistrationServiceUrl": "http://localhost:5001",
    "GlobalCycleIntervalSeconds": 1,
    "Machines": [
      {
        "MachineName": "OpenCN-Machine-001",
        "Enabled": true,
        "ModelPath": "/app/models/opencn-machine-001.onnx",
        "PreprocessingStrategy": "ActuatorCurrentFeatureExtractor",
        "InputSensors": [
          "V1",
          "V2", 
          "V3"
        ],
        "PredictionSensorName": "PredictedCurrentState",
        "WindowSizeSeconds": 1,
        "CycleIntervalSeconds": 1
      }
    ]
  }
}
