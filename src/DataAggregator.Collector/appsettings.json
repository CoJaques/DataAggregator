{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "CollectorType": "OpenCN",
  "Collector": {
    "DeviceId": "Machine-001",
    "DeviceName": "OpenCN-Machine-001",
    "Location": "Manufacturing Floor - Section A",
    "HealthCheckEndpoint": "http://localhost:5000/health",
    "SamplingRate": 500,
    "CfgString": "config=default;mode=production",
    "CapnProto": {
      "ServerAddress": "localhost",
      "Port": 5555,
      "TimeoutMs": 5000
    },
    "RegistrationService": {
      "Endpoint": "http://localhost:5001/api/DeviceRegistration"
    },
    "BufferSettings": {
      "MaxBufferSize": 10000
    },
    "Sensors": [
      {
        "Name": "Temperature",
        "Type": "Temperature",
        "Unit": "Celsius",
        "Metadata": {
          "MinValue": "-10",
          "MaxValue": "100",
          "Precision": "0.1"
        }
      },
      {
        "Name": "Pressure",
        "Type": "Pressure",
        "Unit": "Bar",
        "Metadata": {
          "MinValue": "0",
          "MaxValue": "10",
          "Precision": "0.01"
        }
      },
      {
        "Name": "Vibration",
        "Type": "Vibration",
        "Unit": "Hz",
        "Metadata": {
          "MinValue": "0",
          "MaxValue": "1000",
          "Precision": "1"
        }
      }
    ]
  }
}
