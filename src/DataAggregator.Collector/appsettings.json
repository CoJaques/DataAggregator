{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "CollectorType": "OpenCN",
  "Collector": {
    "DeviceId": "Machine-001",
    "DeviceName": "OpenCN-Machine-001",
    "Location": "Manufacturing Floor - Section A",
    "HealthCheckEndpoint": "http://localhost:5000/health",
    "SamplingRate": 500,
    "CapnProto": {
      "ServerAddress": "192.168.53.15",
      "Port": 7002,
      "TimeoutMs": 5000
    },
    "RegistrationService": {
      "Endpoint": "http://localhost:5137/api/DeviceRegistration/register"
    },
    "BufferSettings": {
      "MaxBufferSize": 10000
    },
    "Sensors": [
      {
        "Name": "V1",
        "Type": "V1",
        "Unit": "U1",
        "Metadata": {
          "MinValue": "-10",
          "MaxValue": "100"
        },
        "DataType": "float",
        "PinName":  "streamer.0.pin.0"
      },
      {
        "Name": "V2",
        "Type": "V2",
        "Unit": "Bar",
        "PinName": "streamer.0.pin.1",
        "DataType": "float"
      },
      {
        "Name": "V3",
        "Type": "V3",
        "Unit": "Hz",
        "PinName": "streamer.0.pin.2",
        "DataType": "float"
      }
    ]
  }
}
